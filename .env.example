# AetherCall AI Environment Variables Template
# Copy this file to .env and fill in your details:
# cp .env.example .env

# Gmail Credentials for real Nodemailer OTP dispatch
EMAIL_USER=your_gmail_username@gmail.com
EMAIL_PASS=your_16_character_app_password

# Port configurations (defaults to 3000)
PORT=3000

# MongoDB local connection URI
MONGODB_URI=mongodb://localhost:27017/ai-video-conference

# Resend API Key for Email OTP (Free tier outbound mail)
RESEND_API_KEY=your_resend_api_key_here
